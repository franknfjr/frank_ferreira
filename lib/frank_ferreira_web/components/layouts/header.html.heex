<% path = @conn.request_path %>
<% active =
  cond do
    path == "/" -> "home"
    String.starts_with?(path, "/blog") -> "writing"
    String.starts_with?(path, "/projects") -> "projects"
    String.starts_with?(path, "/about") -> "about"
    String.starts_with?(path, "/uses") -> "uses"
    String.starts_with?(path, "/contact") -> "contact"
    true -> nil
  end %>
<header class="ff-header">
  <a href="/" class="ff-brand">
    <span class="ff-glyph">F</span> frank.ferreira
  </a>

  <nav class="ff-nav">
    <a href="/" class={if active == "home", do: "is-active", else: ""}>
      <%= gettext("nav.index") %>
    </a>
    <a href="/blog" class={if active == "writing", do: "is-active", else: ""}>
      <%= gettext("nav.writing") %>
    </a>
    <a href="/projects" class={if active == "projects", do: "is-active", else: ""}>
      <%= gettext("nav.projects") %>
    </a>
    <a href="/about" class={if active == "about", do: "is-active", else: ""}>
      <%= gettext("nav.about") %>
    </a>
    <a href="/uses" class={if active == "uses", do: "is-active", else: ""}>
      <%= gettext("nav.uses") %>
    </a>
  </nav>

  <div class="ff-header-right">
    <.language_select
      current_path={@conn.request_path}
      current_locale={Gettext.get_locale(FrankFerreiraWeb.Gettext)}
      language_options={FrankFerreira.config(:language_options)}
    />
    <button
      phx-click={JS.dispatch("toogle-darkmode")}
      class="ff-locale"
      aria-label="Toggle dark mode"
      style="background:transparent;border:0;cursor:pointer;padding:4px;"
    >
      <svg
        class="w-4 h-4 hidden dark:block"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"
        />
      </svg>
      <svg
        class="w-4 h-4 block dark:hidden"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"
        />
      </svg>
    </button>
  </div>
</header>
