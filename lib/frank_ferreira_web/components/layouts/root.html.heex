<!DOCTYPE html>
<html
  lang={Gettext.get_locale(FrankFerreiraWeb.Gettext) |> String.replace("br", "pt-BR")}
  class="[scrollbar-gutter:stable]"
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <SEO.juice
      conn={@conn}
      config={FrankFerreiraWeb.SEO}
      item={SEO.item(@conn)}
      page_title={assigns[:page_title]}
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script
      defer
      data-exclude="/admin/*"
      data-domain="frankferreira.dev"
      src="/js/plausible_script.js"
    >
    </script>

    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
    <script type="text/javascript">
      // On page load or when changing themes, best to add inline in `head` to avoid FOUC
      if (
        !window.matchMedia('print').matches &&
        localStorage.theme === 'dark' ||
        (
          !('theme' in localStorage) &&
          window.matchMedia('(prefers-color-scheme: dark)').matches
        )
      ) {
        document.documentElement.classList.add('dark')
      } else {
        document.documentElement.classList.remove('dark')
      }
    </script>
  </head>
  <body class="antialiased bg-light-bg text-light-text dark:bg-dark-bg dark:text-dark-text min-h-screen flex flex-col">
    <%= FrankFerreiraWeb.Layouts.header(assigns) %>
    <div class="flex-1">
      <%= @inner_content %>
    </div>
    <%= FrankFerreiraWeb.Layouts.footer(assigns) %>
  </body>
</html>
